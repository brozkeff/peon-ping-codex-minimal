{
  "schema_version": "1.0",
  "id": "peon-minimal",
  "name": "Peon Minimal",
  "author": "Internal fork from PeonPing",
  "description": "Minimal Warcraft III pack for Codex notifications.",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "PeonReady1.ogg", "label": "Ready" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "PeonYes1.ogg", "label": "Job done" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "PeonWhat1.ogg", "label": "Need input" }
      ]
    }
  }
}
